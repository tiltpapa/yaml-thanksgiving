{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "autoApprove": [
        "navigate_page",
        "take_screenshot",
        "press_key",
        "new_page"
      ]
    },
    "reveal.js": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://gitmcp.io/hakimel/reveal.js"
      ]
    }
  }
}