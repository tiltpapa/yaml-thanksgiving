{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "autoApprove": [
        "navigate_page",
        "take_screenshot",
        "press_key",
        "new_page",
        "take_snapshot",
        "list_pages"
      ]
    },
    "reveal-thanksgiving": {
      "command": "npx",
      "args": [
        "mcp-remote",
        "https://gitmcp.io/tiltpapa/reveal-thanksgiving"
      ]
    }
  }
}